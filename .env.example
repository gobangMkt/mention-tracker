# 네이버 검색 API (https://developers.naver.com)
NAVER_CLIENT_ID=여기에_입력
NAVER_CLIENT_SECRET=여기에_입력

# Google Serper API (https://serper.dev)
SERPER_API_KEY=여기에_입력

# Firebase (https://console.firebase.google.com)
FIREBASE_API_KEY=여기에_입력
FIREBASE_AUTH_DOMAIN=여기에_입력
FIREBASE_PROJECT_ID=여기에_입력
FIREBASE_STORAGE_BUCKET=여기에_입력
FIREBASE_MESSAGING_SENDER_ID=여기에_입력
FIREBASE_APP_ID=여기에_입력

# 서버 포트 (기본값: 3001)
PORT=3001
